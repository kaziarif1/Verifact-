# ─── SERVER ───────────────────────────────────────────────
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:5000

# ─── MONGODB ──────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/verifact

# ─── REDIS ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT (RS256) ─────────────────────────────────────────
# Generate: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Then base64 encode: base64 -w 0 private.pem
JWT_PRIVATE_KEY_BASE64=your_base64_encoded_private_key_here
JWT_PUBLIC_KEY_BASE64=your_base64_encoded_public_key_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── CLOUDINARY ───────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── EMAIL (SMTP) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=Verifact <noreply@verifact.app>

# ─── ML SERVICE ───────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8000
ML_INTERNAL_KEY=your_very_secret_internal_key_here
ML_PROVIDER=remote
ENABLE_REALTIME=true
USE_IN_MEMORY_SERVICES=false
USE_IN_MEMORY_DATABASE=false
USE_IN_MEMORY_REDIS=false
LOCAL_ADMIN_EMAIL=kazarif02@gmail.com
LOCAL_ADMIN_PASSWORD=%Karif10%

# ─── RATE LIMITING ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
